# ===================================
# إعدادات بوت تيك توك الذكي - نسخة Puppeteer
# ===================================

# === بيانات حساب تيك توك (مطلوب!) ===
TIKTOK_USERNAME=اسم_المستخدم_بتاعك
TIKTOK_PASSWORD=كلمة_المرور

# === إعدادات المراقبة ===
# كل كم ثانية يفحص المنشنات (أقل شيء 60)
CHECK_INTERVAL=120

# أقصى عدد ردود لكل فحص
MAX_REPLIES_PER_RUN=5

# === إعدادات البوت ===
BOT_LANGUAGE=ar
BOT_PERSONALITY=friendly
SAFE_MODE=true
