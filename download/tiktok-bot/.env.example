# ===================================
# إعدادات بوت تيك توك الذكي
# ===================================

# معرف حساب تيك توك الخاص بالبوت (بدون @)
TIKTOK_USERNAME=your_bot_username

# كلمة مرور تيك توك
TIKTOK_PASSWORD=your_bot_password

# إعدادات البوت
# عدد الفيديوهات اللي البوت يتفاعل معها كل مرة
MAX_VIDEOS_PER_RUN=10

# الوقت بين كل تفاعل (بالثواني) - عشان تيك توك ما يحظر البوت
DELAY_BETWEEN_ACTIONS=30

# اللغة الافتراضية للردود
BOT_LANGUAGE=ar

# نمط شخصية البوت
BOT_PERSONALITY=friendly

# هاشتاقات البوت يبحث عنها
TARGET_HASHTAGS=funny,comedy,daily,vlog,cooking,art,music

# أسماء حسابات البوت يتفاعل معها (اختياري، بدون @)
TARGET_USERS=

# تشغيل الوضع الآمن (فلترة المحتوى الحساس)
SAFE_MODE=true
